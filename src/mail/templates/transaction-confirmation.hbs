<h2 style="margin-top:0;color:#0b5fff;">Transaction confirmed</h2>
<p style="margin:0 0 16px;line-height:1.6;">Hi {{fullName}},</p>
<p style="margin:0 0 16px;line-height:1.6;">Your transaction has been processed successfully.</p>
<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse:collapse;margin-bottom:16px;">
  <tr>
    <td style="padding:8px 0;font-weight:700;">Transaction ID</td>
    <td style="padding:8px 0;text-align:right;">{{transactionId}}</td>
  </tr>
  <tr>
    <td style="padding:8px 0;font-weight:700;">Date</td>
    <td style="padding:8px 0;text-align:right;">{{date}}</td>
  </tr>
  <tr>
    <td style="padding:8px 0;font-weight:700;">Amount</td>
    <td style="padding:8px 0;text-align:right;">{{amount}}</td>
  </tr>
  <tr>
    <td style="padding:8px 0;font-weight:700;">Status</td>
    <td style="padding:8px 0;text-align:right;">{{status}}</td>
  </tr>
</table>
<p style="margin:0 0 16px;line-height:1.6;">Details: {{description}}</p>
<p style="margin:0;line-height:1.6;">Thank you for using NexaFx.</p>
